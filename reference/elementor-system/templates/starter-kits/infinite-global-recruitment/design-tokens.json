        "heading_weight": "700",
        "body_font": "DM Sans",
        "body_weight": "400",
        "overline": {
            "font": "DM Sans",
            "size": "14px",
            "weight": "600",
            "letter_spacing": "2-3px",
            "text_transform": "uppercase",
            "color": "#C49A3C"
        },
        "scale": {
            "display": {"desktop": "56px", "tablet": "42px", "mobile": "32px", "weight": "800", "line_height": "1.1em"},
            "h1": {"desktop": "44px", "tablet": "36px", "mobile": "28px", "weight": "700", "line_height": "1.2em"},
            "h2": {"desktop": "36px", "tablet": "30px", "mobile": "24px", "weight": "700", "line_height": "1.2em"},
            "h3": {"desktop": "28px", "tablet": "24px", "mobile": "20px", "weight": "600", "line_height": "1.3em"},
            "h4": {"desktop": "22px", "tablet": "20px", "mobile": "18px", "weight": "600", "line_height": "1.3em"},
            "h5": {"desktop": "18px", "tablet": "16px", "mobile": "16px", "weight": "600", "line_height": "1.4em"},
            "body_large": {"desktop": "18px", "tablet": "18px", "mobile": "16px", "weight": "400", "line_height": "1.8em"},
            "body": {"desktop": "16px", "tablet": "16px", "mobile": "15px", "weight": "400", "line_height": "1.6em"},
